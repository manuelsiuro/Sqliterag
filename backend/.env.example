# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Database
DATABASE_URL=sqlite+aiosqlite:///./sqliterag.db

# Default model
DEFAULT_MODEL=qwen3.5:9b

# Embedding model
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=256

# RAG settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=5

# Server
HOST=0.0.0.0
PORT=8000
